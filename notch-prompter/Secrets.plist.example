<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Copy this file to Secrets.plist (same directory) and fill in real values.
      Secrets.plist is gitignored — it ships only inside private team builds
      produced by scripts/build-team-release.sh, never in the public repo.
      User-set Keychain values (Settings → API Keys) override anything here.
    -->
    <key>ANTHROPIC_API_KEY</key>
    <string>sk-ant-PASTE-YOUR-KEY-HERE</string>
    <key>ELEVENLABS_API_KEY</key>
    <string>sk_PASTE-YOUR-KEY-HERE</string>
</dict>
</plist>
